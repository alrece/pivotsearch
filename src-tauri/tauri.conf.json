{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pivotsearch",
  "version": "0.3.0",
  "identifier": "com.pivotsearch.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "beforeBundleCommand": "node scripts/prepare-sidecar.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "PivotSearch",
        "width": 1000,
        "height": 700,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "macOS": {
      "signingIdentity": null,
      "entitlements": null
    },
    "externalBin": ["binaries/psearch"]
  }
}
